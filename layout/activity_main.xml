<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#001020"
    android:gravity="center"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:text="Sound Meter"
        android:textColor="#ffffff"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <LinearLayout
        android:id="@+id/startLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#00C853"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:id="@+id/startText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Click to allow microphone"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <View
            android:id="@+id/recordingIndicator"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/green_circle"
            android:visibility="gone" />

    </LinearLayout>


    <Button
        android:id="@+id/viewReportBtn"
        android:text="View Live Report"
        android:backgroundTint="#FFC107"
        android:textColor="#000"
        android:layout_marginTop="20dp"
        android:layout_height="wrap_content"
        android:layout_width="match_parent" />


    <LinearLayout
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/txtMin"
            android:text="MIN\n0"
            android:textColor="#00FFFF"
            android:gravity="center"
            android:textAlignment="center"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/txtMax"
            android:text="MAX\n0"
            android:textColor="#00FFFF"
            android:gravity="center"
            android:textAlignment="center"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/txtAvg"
            android:text="AVG\n0"
            android:textColor="#00FFFF"
            android:gravity="center"
            android:textAlignment="center"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

    </LinearLayout>


    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="20dp">

        <!-- COLOR BAR -->
        <ProgressBar
            android:id="@+id/progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:max="140"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:progressDrawable="@drawable/progress_sound"/>

        <!-- ARROW -->
        <ImageView
            android:id="@+id/dbArrow"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="top|start"
            android:src="@drawable/arrow_up"
            android:translationY="25dp" />

    </FrameLayout>


    <FrameLayout
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_marginTop="40dp"
        android:layout_gravity="center"
        android:background="@drawable/circle_bg">

        <TextView
            android:id="@+id/txtDb"
            android:text="-- dB"
            android:textColor="#00FFFF"
            android:textSize="40sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </FrameLayout>


    <Button
        android:id="@+id/startBtn"
        android:text="CLICK TO START"
        android:backgroundTint="#00C853"
        android:textColor="#000"
        android:layout_marginTop="40dp"
        android:layout_width="match_parent"
        android:layout_height="60dp"/>

</LinearLayout>
